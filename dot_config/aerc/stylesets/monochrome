# aerc monochrome styleset (modified)

*.default = true
*.normal = true

# Selected item: white text on black background
*.selected.fg = 15        # white text
*.selected.bg = 0         # black background

# Simulated “border” effect using reverse toggle highlight (optional)
*.selected.reverse = false
*.selected.bold = true
*.selected.italic = true

# Optional: “pill” style (for tags, etc.)
*_pill.reverse = true

title.reverse = true
title.bold = true
header.bold = true
tab.selected.bold = true
dirlist*.selected.bold = true

statusline_default.reverse = false
*error.bold = true
*error.fg = 1
*warning.fg = 3

msglist_unread.bold = true
msglist_deleted.dim = true
msglist_result.underline = true

part_mimetype.dim = true
part_mimetype.selected.dim = false
part_filename.selected.bold = true

selector_focused.reverse = true
selector_chooser.bold = true
completion_description.dim = true

[viewer]
*.default = true
*.normal = true
url.underline = true
header.bold = true
signature.dim = true
diff_meta.bold = true
diff_chunk*.dim = true
diff_add.fg = 2
diff_del.fg = 1
quote_*.fg = 6
quote_*.dim = true
quote_1.dim = false
