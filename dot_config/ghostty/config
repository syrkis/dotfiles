# Ghostty Configuration
# Basic configuration with sensible defaults
auto-update-channel = tip
custom-shader = ~/.config/ghostty/cursor_sweep.glsl
shell-integration = fish


# Font Configuration
font-family = "Uiua386"
font-size = 18
# letter-spacing = 5
adjust-cell-width = 2
adjust-cell-height = 27
term=xterm-256color

# Theme Configuration - adapts to system light/dark mode
theme = light:Xcode Light,dark:Black Metal (Marduk) 

# Cursor Configuration
cursor-style = block
split-divider-color = #000000
# cursor-color = #ffffff

# Window Configuration
window-padding-x = 8
window-padding-y = 8
unfocused-split-opacity = 1
background-opacity-cells = 0
background-opacity = 1.0
background-blur = macos-glass-clear
# background = false

# Terminal Behavior
scrollback-limit = 10000
copy-on-select = false
clipboard-trim-trailing-spaces = true

# Shell Integration

# Mouse Configuration
mouse-hide-while-typing = true
mouse-scroll-multiplier = 3


# Quality of life improvements
confirm-close-surface = true
quit-after-last-window-closed = false
initial-window = false
window-inherit-working-directory = true
window-inherit-font-size = true


# Quick Terminal (Dropdown) Configuration
quick-terminal-position = bottom
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.1


# Global keybind for dropdown terminal
keybind = global:alt+space=toggle_quick_terminal 

# macOS specific settings (only applied on macOS)
# macos-option-as-alt = true
# macos-titlebar-style = hidden
# keybind = shift+enter=text:\n
macos-option-as-alt = "right"
# window-decoration = none
macos-titlebar-style = hidden
